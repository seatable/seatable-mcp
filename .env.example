# SeaTable configuration
SEATABLE_SERVER_URL=
SEATABLE_API_TOKEN=
SEATABLE_BASE_UUID=
# Optional default table
SEATABLE_TABLE_NAME=
# Optional: use in-memory mock client for local testing (true/1 to enable)
SEATABLE_MOCK=
# Optional: expiry string for app-access-token (e.g., 3d, 1h). Defaults to 1h if not set
SEATABLE_ACCESS_TOKEN_EXP=
# Optional: override token exchange path. Examples:
#   For app-access-token: /api/v2.1/dtable/app-access-token/
#   For base-token: /api/v2.1  or  /api/v2  or  /dtable-server/api/v1
SEATABLE_TOKEN_ENDPOINT_PATH=

# Server mode: selfhosted (default) or managed (multi-tenant HTTP with per-client auth)
SEATABLE_MODE=selfhosted

# Multi-base mode (selfhosted only): serve multiple bases from one process.
# Comma-separated "Name:token" pairs. Use instead of SEATABLE_API_TOKEN.
# SEATABLE_BASES=CRM:token_abc,Projects:token_def
