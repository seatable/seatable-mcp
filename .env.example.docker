# Docker Compose configuration for managed HTTP mode (mcp.seatable.com)

# Required: public hostname for Caddy TLS
SEATABLE_MCP_HOSTNAME=mcp.example.com

# Required: SeaTable server URL for token validation
SEATABLE_SERVER_URL=https://cloud.seatable.io

# Auth: single-base token or multi-base JSON array
# SEATABLE_API_TOKEN=your-api-token
# SEATABLE_BASES='[{"base_name":"CRM","api_token":"..."},{"base_name":"Projects","api_token":"..."}]'
